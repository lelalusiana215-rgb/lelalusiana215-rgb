{
  "entities": {
    "School": {
      "title": "School",
      "description": "Information about the school",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "School name" },
        "address": { "type": "string", "description": "School address" },
        "header_text": { "type": "string", "description": "Header text for reports" },
        "logo_school": { "type": "string", "description": "Base64 school logo" },
        "logo_gov": { "type": "string", "description": "Base64 government logo" },
        "status": { "type": "string", "enum": ["PENDING", "ACTIVE", "REJECTED"], "description": "Approval status" }
      },
      "required": ["name", "status"]
    },
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["KEPALA_SEKOLAH", "GURU", "ADMIN"] },
        "nip": { "type": "string" },
        "teaching_class": { "type": "string" },
        "rank_grade": { "type": "string" },
        "school_id": { "type": "string", "description": "ID of the school" },
        "status": { "type": "string", "enum": ["PENDING", "ACTIVE", "REJECTED"], "description": "Approval status" }
      },
      "required": ["email", "name", "role", "school_id", "status"]
    },
    "Supervision": {
      "title": "Supervision",
      "description": "Academic supervision record",
      "type": "object",
      "properties": {
        "teacher_id": { "type": "string" },
        "principal_id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["BELUM", "PROSES", "SELESAI"] },
        "stage1_date": { "type": "string" },
        "stage2_date": { "type": "string" },
        "stage3_date": { "type": "string" },
        "stage4_date": { "type": "string" },
        "stage5_date": { "type": "string" },
        "stage1_data": { "type": "string", "description": "JSON string of stage 1 data" },
        "stage2_data": { "type": "string", "description": "JSON string of stage 2 data" },
        "stage3_data": { "type": "string", "description": "JSON string of stage 3 data" },
        "stage4_data": { "type": "string", "description": "JSON string of stage 4 data" },
        "stage5_data": { "type": "string", "description": "JSON string of stage 5 data" },
        "final_score": { "type": "number" },
        "recommendations": { "type": "string" }
      },
      "required": ["teacher_id", "principal_id", "date", "status"]
    }
  },
  "firestore": {
    "/schools/{schoolId}": {
      "schema": "School",
      "description": "School details"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/supervisions/{supervisionId}": {
      "schema": "Supervision",
      "description": "Supervision records"
    }
  }
}
